# Copy to .env.local for local testing. Production values live in Vercel env vars.

# Firebase service account JSON (entire JSON, single line). Get it from:
# Firebase Console -> Project Settings -> Service Accounts -> Generate new private key
FIREBASE_SERVICE_ACCOUNT_JSON=

# Realtime Database URL
FIREBASE_DATABASE_URL=https://pretzeldaily-c340a-default-rtdb.firebaseio.com

# ntfy.sh topic — both phones must subscribe to this same string in the ntfy app.
# Treat as a password: anyone who knows the topic can publish + read.
NTFY_TOPIC=

# Random string. cron-job.org sends "Authorization: Bearer $CRON_SECRET" on every ping.
CRON_SECRET=
